# --- Provider selection ---
# Pick one: minimax (default) | claude | codex
D2P_PROVIDER=minimax

# --- MiniMax (default) ---
MINIMAX_API_KEY=sk-cp-...your-token-plan-key...
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M2.7-highspeed

# --- Claude (set D2P_PROVIDER=claude to enable) ---
# Default split: Haiku for executor/fix, Opus for analyzer/planner/qa
ANTHROPIC_API_KEY=sk-ant-...
# Optional overrides — leave unset for defaults
# D2P_ROLE_EXECUTOR_MODEL=claude-haiku-4-5
# D2P_ROLE_PLANNER_MODEL=claude-opus-4-7

# --- Codex / OpenAI (set D2P_PROVIDER=codex to enable) ---
# Default split: gpt-4o-mini for executor/fix, gpt-4o for analyzer/planner/qa
OPENAI_API_KEY=sk-...
# D2P_ROLE_EXECUTOR_MODEL=gpt-4o-mini
# D2P_ROLE_PLANNER_MODEL=gpt-4o
